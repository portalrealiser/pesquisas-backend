# Conexão com o Postgres.
# Use a "Internal Connection URL" que o EasyPanel mostra na seção de credenciais
# do serviço Postgres (substitua SUA_SENHA pelo valor real).
DATABASE_URL=postgres://realiser:SUA_SENHA@n8n_postgress:5432/memoria?sslmode=disable

# Schema dedicado deste sistema dentro do banco "memoria".
# Mantém as tabelas isoladas de qualquer outro sistema que use o mesmo banco no futuro.
DB_SCHEMA=pesquisas

# Porta do servidor. Aponte o "proxy port" do App no EasyPanel para 8080.
PORT=8080
