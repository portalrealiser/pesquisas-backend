# --- Banco de dados ---
# Internal Connection URL do Postgres no EasyPanel (troque SUA_SENHA pela real).
DATABASE_URL=postgres://realiser:SUA_SENHA@n8n_postgress:5432/memoria?sslmode=disable
# Schema dedicado deste sistema dentro do banco "memoria".
DB_SCHEMA=pesquisas

# --- Servidor ---
PORT=3000

# --- Admin ---
# Senha que VOCÊ usa para entrar no painel.
ADMIN_PASSWORD=defina-uma-senha-forte
# Segredo para assinar a sessão (use algo longo e aleatório).
JWT_SECRET=troque-por-um-valor-aleatorio-longo

# --- Anti-duplicação ---
# Salt do hash de IP (use algo longo e aleatório). Nunca guardamos o IP cru.
IP_SALT=troque-por-um-salt-aleatorio
# Liga (true) ou desliga (false) a camada de IP. Desligue se CGNAT barrar gente de boa fé.
IP_DEDUP=true

# --- Cookies / CORS ---
# true em produção (HTTPS).
COOKIE_SECURE=true
# 'lax' se front e back no mesmo domínio; 'none' (com COOKIE_SECURE=true) se domínios diferentes.
COOKIE_SAMESITE=lax
# Origens liberadas para o frontend (ex.: https://meusite.vercel.app). Vazio = sem CORS.
FRONTEND_ORIGIN=
